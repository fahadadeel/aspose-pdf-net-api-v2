[run]
include =
    ./config.py
    ./state.py
    ./persistence.py
    ./pipeline/error_parser.py
    ./pipeline/prompt_builder.py
    ./pipeline/build.py
    ./pipeline/models.py
    ./pipeline/usage_tracker.py
    ./pipeline/runner.py
    ./routers/health.py
    ./routers/jobs.py
    ./middleware/security.py
    ./features/__init__.py
    ./logging_config.py
    ./knowledge/error_fixes.py
    ./knowledge/error_catalog.py
    ./knowledge/auto_fixes.py
    ./knowledge/pattern_tracker.py
    ./knowledge/fix_history.py

omit =
    tests/*
    .venv/*
    scripts/*
    */site-packages/*
    */python3*/*

[report]
show_missing = true
skip_covered = false
