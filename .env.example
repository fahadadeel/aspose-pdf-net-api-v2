# Environment selection: set APP_ENV to load .env.{APP_ENV}
# APP_ENV=production  →  loads .env.production
# APP_ENV=staging     →  loads .env.staging
# (unset)             →  loads .env (local dev)

# ── Secrets ──
LITELLM_API_KEY=sk-your-key-here
LITELLM_API_BASE=https://llm.professionalize.com/v1
REPO_TOKEN=ghp_your-token-here
REPO_USER=your-email@example.com

# ── MCP Server URLs ──
API_URL=http://172.20.1.175:7050/mcp/generate
MCP_RETRIEVE_URL=http://172.20.1.175:7050/mcp/retrieve

# ── Task Generator URLs ──
CATEGORIES_API_URL=http://172.20.1.175:7001/api/categories
TASKS_API_URL=http://172.20.1.175:7001/api/tasks

# ── Git Repo ──
REPO_PATH=/path/to/agentic-net-examples-v2

# ── Build Settings ──
BUILD_TFM=net10.0
NUGET_VERSION=26.2.0
