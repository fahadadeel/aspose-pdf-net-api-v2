    "/api/create-pr-from-results": {
      "post": {
        "description": "Create PR(s) from persisted disk results -- no running pipeline needed.\n\nBody:\n    {\n        \"categories\": [\"working-with-images\", ...],  // optional -- omit for all\n        \"version\": \"26.3.0\",                         // optional -- default from config\n        \"pr_style\": \"per-category\",                  // \"per-category\" or \"single\"\n        \"pr_target_branch\": \"\"                       // optional override\n    }\n\nThe PR will include:\n- All passed .cs files from disk results\n- Rich PR description with example titles, APIs, tags, difficulty stats\n- Per-category agents.md and index.json",
        "operationId": "api_create_pr_from_results_api_create_pr_from_results_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": true,
                "title": "Data",
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {}
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Api Create Pr From Results"
      }
    },
    "/api/failed-tasks/{category}": {
      "get": {
        "description": "Return failed task dicts for a category from disk results.\n\nUsed by the Results Dashboard to send failed tasks to the Build Monitor\nfor retry.  Returns the same task-dict format that /api/start-tasks expects.\n\nThe category param is the disk slug (e.g. \"securing_and_signing_pdf\").\nThe returned task dicts use the original category name from the JSON file\n(e.g. \"Securing and signing PDF\") so run_pipeline handles them correctly.",
        "operationId": "api_failed_tasks_api_failed_tasks__category__get",
        "parameters": [
          {
            "in": "path",
            "name": "category",
            "required": true,
            "schema": {
